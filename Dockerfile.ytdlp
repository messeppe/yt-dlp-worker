FROM python:3.11-slim

RUN apt-get update \
    && apt-get install -y --no-install-recommends ffmpeg \
    && rm -rf /var/lib/apt/lists/*

COPY requirements_ytdlp.txt .
RUN pip install --no-cache-dir -r requirements_ytdlp.txt

WORKDIR /app
COPY worker_ytdlp.py .

CMD ["python", "-u", "worker_ytdlp.py"]
